{
  "$schema": "https://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "operator": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "rustLog": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "builtinPlugins": {
      "type": "object",
      "properties": {
        "install": { "type": "boolean" },
        "namespaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "http": { "$ref": "#/$defs/builtinPlugin" },
        "rabbitmq": { "$ref": "#/$defs/builtinPlugin" },
        "azureServiceBus": { "$ref": "#/$defs/builtinPlugin" }
      }
    }
  },
  "$defs": {
    "builtinPlugin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "workloadIdentity": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "serviceAccountName": { "type": "string" },
            "podAnnotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "operator": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "rustLog": { "type": "string" },
        "auth": {
          "type": "object",
          "properties": {
            "signingSecretNamespace": { "type": "string" },
            "signingSecretName": { "type": "string" },
            "signingSecretKey": { "type": "string" }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "builtinPlugins": {
      "type": "object",
      "properties": {
        "install": { "type": "boolean" },
        "namespaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "http": { "$ref": "#/$defs/builtinPlugin" },
        "rabbitmq": { "$ref": "#/$defs/builtinPlugin" },
        "azureServiceBus": { "$ref": "#/$defs/builtinPlugin" }
      }
    }
  },
  "$defs": {
    "builtinPlugin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "inceptorWorkloadIdentity": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "serviceAccountName": { "type": "string" },
            "podAnnotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "podLabels": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "manager": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "amqpUrl": { "type": "string" },
            "amqpUrlSecretName": { "type": "string" },
            "amqpUrlSecretKey": { "type": "string" },
            "configSecretName": { "type": "string" },
            "configSecretKey": { "type": "string" },
            "connectionStringSecretName": { "type": "string" },
            "connectionStringSecretKey": { "type": "string" },
            "fullyQualifiedNamespace": { "type": "string" },
            "podAnnotations": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "podLabels": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "resources": { "type": "object" },
            "workloadIdentity": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "serviceAccountName": { "type": "string" },
                "podAnnotations": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "podLabels": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" }
          }
        }
      }
    }
  }
}
